# Local docker-compose secrets. Copy to .env (docker compose reads .env automatically).
# Everything else (DB, Redis, MinIO, ports) is wired with local defaults in docker-compose.yml.

# Required to run content/intake jobs (worker calls Claude):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: enables GBP verify + geo research via Gemini grounding.
GEMINI_API_KEY=

# Optional: enables the live Knowledge Base cache from Google Drive.
# Leave blank locally to use the in-repo knowledge-base/ fallbacks.
GOOGLE_DRIVE_KB_FOLDER_ID=
GOOGLE_DRIVE_OAUTH_TOKEN=

# Optional overrides (sane local defaults exist in docker-compose.yml):
# AUTH_SECRET=local-dev-secret-change-me
# WORKER_API_TOKEN=local-worker-token
# SEED_DEFAULT_PASSWORD=localdev123
