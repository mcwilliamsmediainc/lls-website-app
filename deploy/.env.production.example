# LLS droplet .env — copy to repo root as .env before `docker compose up`.
#
# Only the values below are actually read by docker-compose.yml. Postgres, Redis,
# and MinIO connection details are hardcoded inside the compose file (internal
# service names), so do NOT set DATABASE_URL / REDIS_URL / MINIO_* here — they are
# ignored, and the wrong values cause confusion.

# --- Required: the worker calls Claude ---
ANTHROPIC_API_KEY=REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Optional: enables GBP verify + geo research ---
GEMINI_API_KEY=

# --- Optional: live Knowledge Base from Google Drive (else local knowledge-base/ is used) ---
GOOGLE_DRIVE_KB_FOLDER_ID=1ZYap_nnnvj4q7Sx5jFrlnSHb_D4b9EUj
GOOGLE_DRIVE_OAUTH_TOKEN=

# --- Secrets: generate strong random values for a public host ---
# e.g.  openssl rand -hex 32
AUTH_SECRET=REPLACE_ME
WORKER_API_TOKEN=REPLACE_ME
SEED_DEFAULT_PASSWORD=REPLACE_ME

# --- Public host (used by deploy/docker-compose.override.yml) ---
# Set to the droplet's public URL so login cookies, CORS, and onboarding links work.
DROPLET_PUBLIC_URL=http://REPLACE_WITH_DROPLET_IP:5173
