{
  "name": "lls-build-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "LLS Production Build Workspace — internal pipeline app for McWilliams Media (intake → content → review → live).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @lls/api dev",
    "dev:web": "pnpm --filter @lls/web dev",
    "dev:worker": "pnpm --filter @lls/worker dev",
    "db:generate": "pnpm --filter @lls/db generate",
    "db:migrate": "pnpm --filter @lls/db migrate",
    "db:seed": "pnpm --filter @lls/db seed",
    "gate": "tsx style-gate/gate.ts",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "start:api": "pnpm --filter @lls/api start",
    "start:worker": "pnpm --filter @lls/worker start"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
