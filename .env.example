# ============================================================
# LLS Production Build Workspace — environment variables
# Copy to .env and fill in. Never commit .env.
# ============================================================

# ---- Anthropic (content generation) ----
ANTHROPIC_API_KEY=
# Spec v5.3 Section: Claude API. Default Sonnet model; worker falls back to
# the next available Sonnet if this one is unavailable. Never block a build
# on a model preference.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1000
ANTHROPIC_MAX_TOKENS_PAGE=8000

# ---- Supabase (PostgreSQL + Vault) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Pooled connection string for Drizzle (transaction pooler recommended on Supabase)
DATABASE_URL=

# ---- Redis (Upstash or DO managed) — BullMQ ----
REDIS_URL=

# ---- DigitalOcean Spaces (S3-compatible) ----
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ---- Gemini (GBP grounding + Imagen) ----
GEMINI_API_KEY=

# ---- OpenAI (DALL-E 3 image fallback — Phase 3) ----
OPENAI_API_KEY=

# ---- Replicate (Stable Diffusion — Phase 3) ----
REPLICATE_API_KEY=

# ---- Google Drive MCP (Knowledge Base folder) ----
GOOGLE_DRIVE_KB_FOLDER_ID=1ZYap_nnnvj4q7Sx5jFrlnSHb_D4b9EUj
GOOGLE_DRIVE_OAUTH_TOKEN=
# Google Drive MCP endpoint (read-only at job dispatch time)
GOOGLE_DRIVE_MCP_URL=https://drivemcp.googleapis.com/mcp/v1

# ---- Auth (Auth.js + TOTP MFA) ----
AUTH_SECRET=
NEXTAUTH_URL=https://create.locallaunchsystem.com
# TOTP issuer label shown in authenticator apps
TOTP_ISSUER=LLS Build Workspace
# Require MFA for every account. false during internal testing; set true before
# client-facing launch (accounts without a provisioned TOTP secret cannot log in).
MFA_REQUIRED=false

# ---- SSH deployment ----
# Per-client SSH deploy keys are stored in Supabase Vault — no env var needed.
# Staging host that receives rsync + WP-CLI pushes:
STAGING_SSH_HOST=staging.locallaunchsystem.com
STAGING_SSH_USER=deploy
STAGING_WEBROOT=/var/www

# ---- Worker behavior ----
# Base URL the worker uses to call back into the API
API_BASE_URL=http://localhost:3000
# Shared secret the worker presents on internal API callbacks (x-worker-token).
# Generate a strong random value and set the same value for API and worker.
WORKER_API_TOKEN=
# Ordered Sonnet fallbacks if ANTHROPIC_MODEL is unavailable
ANTHROPIC_FALLBACK_MODELS=claude-sonnet-4-5,claude-3-5-sonnet-latest
# Max concurrent full site builds (spec: max 3)
CONCURRENT_BUILDS=3
# Worker heartbeat interval (ms)
HEARTBEAT_INTERVAL_MS=60000
# KB cache refresh interval (ms) — spec: 60 minutes
KB_CACHE_REFRESH_MS=3600000
WORKER_ID=worker-1

# ---- Alerting / monitoring ----
ALERT_EMAIL=matt@mcwilliamsmedia.com
SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=

# ---- App ----
PORT=3000
NODE_ENV=development
APP_URL=https://create.locallaunchsystem.com
DEV_URL=https://mcwdevs.com
# Comma-separated allowed CORS origins for the web client
CORS_ORIGINS=http://localhost:5173,https://create.locallaunchsystem.com,https://create.mcwilliamsmedia.com
# Base URL used when generating Brain Injection onboarding links
ONBOARDING_BASE_URL=https://create.locallaunchsystem.com
